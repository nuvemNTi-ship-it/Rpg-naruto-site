<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8">
    <title>SMTEI - Comando Central</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #1a1a1a; color: #fff; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding-top: 100px; }
        .login-card { background: #262626; border: 1px solid #333; padding: 40px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .admin-interface { display: none; }
        .form-control { background: #333; border: 1px solid #444; color: #fff; }
        .form-control:focus { background: #333; color: #fff; border-color: #06A3DA; box-shadow: none; }
    </style>
</head>
<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 login-card" id="area-login">
                <h3 class="text-primary mb-4 text-center">AUTENTICAÇÃO SMTEI</h3>
                <input type="password" id="senha" class="form-control mb-3" placeholder="Chave de Acesso">
                <button onclick="logar()" class="btn btn-primary w-100 fw-bold">ENTRAR NO SISTEMA</button>
            </div>

            <div class="col-md-10 login-card admin-interface" id="area-admin">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="text-success m-0">PAINEL DE PUBLICAÇÃO</h3>
                    <button class="btn btn-outline-danger btn-sm" onclick="location.reload()">SAIR</button>
                </div>
                
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Título da Matéria ou Edital</label>
                        <input type="text" id="titulo" class="form-control" placeholder="Ex: Novo Edital 005/2026">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Tipo</label>
                        <select id="tipo" class="form-select bg-dark text-white border-secondary">
                            <option value="MATÉRIA">Matéria</option>
                            <option value="EDITAL">Edital Oficial</option>
                            <option value="AVISO">Aviso WhatsApp</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Conteúdo (Cole do WhatsApp aqui)</label>
                        <textarea id="conteudo" class="form-control" rows="6" placeholder="Texto da mensagem..."></textarea>
                    </div>
                    <div class="col-12 text-end">
                        <button onclick="limparMural()" class="btn btn-link text-danger me-3">Limpar Mural Público</button>
                        <button onclick="publicar()" class="btn btn-success px-5 fw-bold">LANÇAR NO PORTAL</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const SENHA_MESTRA = "admin123"; // Troque aqui sua senha

        function logar() {
            const s = document.getElementById('senha').value;
            if(s === SENHA_MESTRA) {
                document.getElementById('area-login').style.display = 'none';
                document.getElementById('area-admin').style.display = 'block';
            } else { alert("Acesso Negado."); }
        }

        function publicar() {
            const t = document.getElementById('titulo').value;
            const c = document.getElementById('conteudo').value;
            const tp = document.getElementById('tipo').value;

            if(!t || !c) return alert("Preencha todos os campos.");

            const novoPost = {
                titulo: t,
                conteudo: c,
                tipo: tp,
                data: new Date().toLocaleDateString('pt-BR'),
                hora: new Date().toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'})
            };

            let posts = JSON.parse(localStorage.getItem('ntei_posts')) || [];
            posts.unshift(novoPost); // Adiciona no topo
            localStorage.setItem('ntei_posts', JSON.stringify(posts));

            alert("Publicado com sucesso!");
            document.getElementById('titulo').value = "";
            document.getElementById('conteudo').value = "";
        }

        function limparMural() {
            if(confirm("Deseja apagar TUDO o que foi postado no portal?")) {
                localStorage.removeItem('ntei_posts');
                alert("Mural limpo.");
            }
        }
    </script>
</body>
</html>
